# ═══════════════════════════════════════════════════════════
# TELEGRAM (https://my.telegram.org)
# ═══════════════════════════════════════════════════════════
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Birinchi marta mahalliy ishga tushiring, keyin shu yerga qo'ying
TELEGRAM_SESSION=

# ═══════════════════════════════════════════════════════════
# SUNIY INTELLEKT
# Groq bepul: https://console.groq.com
# ═══════════════════════════════════════════════════════════
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Gemini (zaxira): AI_PROVIDER=gemini qiling
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# ═══════════════════════════════════════════════════════════
# BAZA
# Mahalliy: SQLite (DATABASE_PATH)
# Render/Production: Supabase PostgreSQL (DATABASE_URL)
# ═══════════════════════════════════════════════════════════
DATABASE_PATH=./data/soatbay.db
# DATABASE_URL=postgresql://postgres:PAROL@db.xxxxx.supabase.co:5432/postgres

# ═══════════════════════════════════════════════════════════
# SERVER
# Render PORT ni o'zi beradi — qo'lda yozmang!
# ═══════════════════════════════════════════════════════════
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:4200

# Navbat (Render free 512MB uchun pastroq)
QUEUE_CONCURRENCY=8
AI_QUEUE_CONCURRENCY=3

# Admin panel himoyasi (production da MAJBURIY)
# Yaratish: bash scripts/generate-api-key.sh
ADMIN_API_KEY=
