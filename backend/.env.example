# ═══════════════════════════════════════════════════════════
# TELEGRAM (https://my.telegram.org)
# ═══════════════════════════════════════════════════════════
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Birinchi marta mahalliy ishga tushiring, keyin shu yerga qo'ying
TELEGRAM_SESSION=

# ═══════════════════════════════════════════════════════════
# SUNIY INTELLEKT
# Groq bepul: https://console.groq.com
# ═══════════════════════════════════════════════════════════
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Gemini (zaxira): AI_PROVIDER=gemini qiling
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# ═══════════════════════════════════════════════════════════
# BAZA
# Mahalliy: SQLite (DATABASE_PATH)
# Render/Production: Supabase **connection pooler** (6543) — to'g'ridan-to'g'ri db.xxx:5432 Render da ishlamaydi
# Supabase → Settings → Database → Connection string → URI → Use connection pooling
# DATABASE_URL=postgresql://postgres.xxxxx:PAROL@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_PATH=./data/soatbay.db

# ═══════════════════════════════════════════════════════════
# SERVER
# ═══════════════════════════════════════════════════════════
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:4200

# Navbat (Render free 512MB uchun pastroq)
QUEUE_CONCURRENCY=8
AI_QUEUE_CONCURRENCY=3

# Broadcast xabar yuborish (Telegram spam/blok himoyasi)
BROADCAST_DELAY_MS=4000
BROADCAST_DELAY_JITTER_MS=3000
BROADCAST_PAUSE_EVERY=10
BROADCAST_PAUSE_MS=120000
BROADCAST_MAX_PER_HOUR=30

# Admin panel himoyasi (production da MAJBURIY)
# Yaratish: bash scripts/generate-api-key.sh
ADMIN_API_KEY=
